@model CategoryAdminIndexViewModel
@{
    ViewData["Title"] = "Categories";
}

<h1>Categories</h1>

<p>
    <a asp-action="Create" class="btn">Create New Category</a>
</p>

<form method="get" asp-action="Index" class="search-form">
    <input type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Search by name..." />

    <button type="submit" class="btn">Search</button>

    @if (!string.IsNullOrEmpty(Model.SearchTerm))
    {
        <a asp-action="Index" class="btn">Clear Search</a>
    }
</form>

<!-- results info -->
<p>
    Showing @Model.Categories.Count of @Model.TotalCategories categories
    @if (!string.IsNullOrEmpty(Model.SearchTerm))
    {
        <text> matching "@Model.SearchTerm"</text>
    }
</p>

<!-- categories table -->
@if (Model.Categories == null || Model.Categories.Count == 0)
{
    <p>No categories found.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model.Categories)
            {
                <tr>
                    <td>@category.Name</td>
                    <td>@category.Description</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-small">Edit</a>
                        <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-small">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- pagination -->
@if (Model.TotalPages > 1)
{
    <div class="pagination">
        @if (Model.CurrentPage > 1)
        {
            <a asp-action="Index"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-page="@(Model.CurrentPage - 1)"
               class="btn btn-small">Previous</a>
        }

        <span>Page @Model.CurrentPage of @Model.TotalPages</span>

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a asp-action="Index"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-page="@(Model.CurrentPage + 1)"
               class="btn btn-small">Next</a>
        }
    </div>
}