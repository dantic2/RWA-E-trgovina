@model List<OrderViewModel>
@{
    ViewData["Title"] = "My Orders";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
}

<h1>My Orders</h1>

@if (Model == null || Model.Count == 0)
{
    <p>You haven't placed any orders yet.</p>
    <p><a asp-controller="Product" asp-action="Browse" class="btn">Start Shopping</a></p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Order Number</th>
                <th>Order Date</th>
                <th>Total Amount</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.OrderNumber</td>
                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>€@order.TotalAmount.ToString("F2")</td>
                    <td>
                        <span class="status-badge status-@order.Status.ToLower()">
                            @order.Status
                        </span>
                    </td>
                    <td>
                        <a asp-action="MyOrderDetails" asp-route-id="@order.Id" class="btn btn-small">View Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- pagination -->
    @if (totalPages > 1)
    {
        <div class="pagination">
            @if (currentPage > 1)
            {
                <a asp-action="MyOrders"
                   asp-route-page="@(currentPage - 1)"
                   class="btn btn-small">Previous</a>
            }

            <span>Page @currentPage of @totalPages</span>

            @if (currentPage < totalPages)
            {
                <a asp-action="MyOrders"
                   asp-route-page="@(currentPage + 1)"
                   class="btn btn-small">Next</a>
            }
        </div>
    }
}