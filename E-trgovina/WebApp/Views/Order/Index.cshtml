@model OrderAdminIndexViewModel
@{
    ViewData["Title"] = "Orders (Admin)";
}

<h1>All Orders</h1>

<form method="get" asp-action="Index" class="search-form">
    <input type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Search by customer name or email..." />

    <select name="status" asp-items="Model.StatusOptions">
        <option value="">All Statuses</option>
    </select>

    <button type="submit" class="btn">Search</button>

    @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.Status))
    {
        <a asp-action="Index" class="btn">Clear Filters</a>
    }
</form>

<!-- results info -->
<p>
    Showing @Model.Orders.Count of @Model.TotalOrders orders
    @if (!string.IsNullOrEmpty(Model.SearchTerm))
    {
        <text> matching "@Model.SearchTerm"</text>
    }
    @if (!string.IsNullOrEmpty(Model.Status))
    {
        <text> with status "@Model.Status"</text>
    }
</p>

<!-- orders table -->
@if (Model.Orders == null || Model.Orders.Count == 0)
{
    <p>No orders found.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Orders[0].OrderNumber)</th>
                <th>@Html.DisplayNameFor(model => model.Orders[0].CustomerName)</th>
                <th>@Html.DisplayNameFor(model => model.Orders[0].OrderDate)</th>
                <th>@Html.DisplayNameFor(model => model.Orders[0].TotalAmount)</th>
                <th>@Html.DisplayNameFor(model => model.Orders[0].Status)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model.Orders)
            {
                <tr>
                    <td>@order.OrderNumber</td>
                    <td>
                        @order.CustomerName<br />
                        <small>@order.CustomerEmail</small>
                    </td>
                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>€@order.TotalAmount.ToString("F2")</td>
                    <td>
                        <span class="status-badge status-@order.Status.ToLower()">
                            @order.Status
                        </span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-small">View Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- pagination -->
@if (Model.TotalPages > 1)
{
    <div class="pagination">
        @if (Model.CurrentPage > 1)
        {
            <a asp-action="Index"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-status="@Model.Status"
               asp-route-page="@(Model.CurrentPage - 1)"
               class="btn btn-small">Previous</a>
        }

        <span>Page @Model.CurrentPage of @Model.TotalPages</span>

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a asp-action="Index"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-status="@Model.Status"
               asp-route-page="@(Model.CurrentPage + 1)"
               class="btn btn-small">Next</a>
        }
    </div>
}