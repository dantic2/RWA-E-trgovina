@model ProductAdminIndexViewModel
@{
    ViewData["Title"] = "Products (Admin)";
}

<h1>Products</h1>

<p>
    <a asp-action="Create" class="btn">Create New Product</a>
</p>

<form method="get" asp-action="Index" class="search-form">
    <input type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Search by title..." />

    <select name="categoryId" asp-items="Model.Categories">
        <option value="">All Categories</option>
    </select>

    <button type="submit" class="btn">Search</button>

    @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.CategoryId.HasValue)
    {
        <a asp-action="Index" class="btn">Clear Filters</a>
    }
</form>

<!-- results -->
<p>
    Showing @Model.Products.Count of @Model.TotalProducts products
    @if (!string.IsNullOrEmpty(Model.SearchTerm))
    {
        <text> matching "@Model.SearchTerm"</text>
    }
    @if (Model.CategoryId.HasValue)
    {
        var selectedCategory = Model.Categories?.FirstOrDefault(c => c.Value == Model.CategoryId.ToString());
        if (selectedCategory != null)
        {
            <text> in category "@selectedCategory.Text"</text>
        }
    }
</p>

<!-- prducts table -->
@if (Model.Products == null || Model.Products.Count == 0)
{
    <p>No products found.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Title</th>
                <th>Price</th>
                <th>Category</th>
                <th>Image</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model.Products)
            {
                <tr>
                    <td>@product.Title</td>
                    <td>€@product.Price.ToString("F2")</td>
                    <td>@product.CategoryName</td>
                    <td>
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" alt="@product.Title" style="max-width: 50px; max-height: 50px;" />
                        }
                        else
                        {
                            <span>No image</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-small">Edit</a>
                        <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-small">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- pagination -->
@if (Model.TotalPages > 1)
{
    <div class="pagination">
        @if (Model.CurrentPage > 1)
        {
            <a asp-action="Index"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-categoryId="@Model.CategoryId"
               asp-route-page="@(Model.CurrentPage - 1)"
               class="btn btn-small">Previous</a>
        }

        <span>Page @Model.CurrentPage of @Model.TotalPages</span>

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a asp-action="Index"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-categoryId="@Model.CategoryId"
               asp-route-page="@(Model.CurrentPage + 1)"
               class="btn btn-small">Next</a>
        }
    </div>
}